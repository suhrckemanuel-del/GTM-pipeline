# Copy to .env and fill in your keys. .env is gitignored and never committed.

# Anthropic — https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# Exa — https://exa.ai/api (news enrichment / signal layer)
EXA_API_KEY=

# Hunter.io — https://hunter.io/api-documentation (contact discovery)
HUNTER_API_KEY=

# Notion — https://www.notion.so/my-integrations (create an internal integration)
NOTION_API_KEY=
NOTION_DATABASE_ID=   # the long hex ID from your Notion DB URL

# Gmail — create App Password at myaccount.google.com/apppasswords (requires 2FA on)
GMAIL_SENDER=suhrckemanuel@gmail.com
GMAIL_APP_PASSWORD=
